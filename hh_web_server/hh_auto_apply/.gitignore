# Переменные окружения (содержат логины/пароли)
config/.env

# Виртуальное окружение
venv/
.venv/
env/

# Python-кеш
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Тестовые артефакты
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# База данных и сессии (локальные данные)
data/*.db
session.pkl

# Логи
logs/*.log

# Debug-файлы от браузера
*.html
*_debug*

# Временные файлы
*.tmp
*.swp
*.swo
.DS_Store

# IDE
.idea/
.vscode/
*.iml
