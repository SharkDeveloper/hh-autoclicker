# ============================================================
# HH Auto Apply — переменные окружения
# Скопируйте в config/.env и заполните своими данными
# ============================================================

# Учётные данные hh.ru (переопределяют config/default.json)
HH_USERNAME=your_email@gmail.com
HH_PASSWORD=your_password

# Настройки планировщика (для prod-профиля Docker)
SCHEDULER_INTERVAL=36   # интервал в минутах 
SCHEDULER_MODE=auto       # auto | recommendations

# Настройки интеграционного теста (для test-профиля Docker)
HH_TEST_KEYWORDS=Python
HH_TEST_AREA=1
