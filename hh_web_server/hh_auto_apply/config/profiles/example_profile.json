{
  "name": "Пример профиля",
  "description": "Пример конфигурационного профиля",
  "credentials": {
    "username": "your_email@example.com",
    "password": "your_password"
  },
  "application": {
    "headless": true,
    "rate_limit": 20,
    "delay_range": [1, 3],
    "dry_run": false
  },
  "search_filters": {
    "text": "Python разработчик",
    "area": "1", 
    "salary": 100000,
    "experience": "between3And6",
    "employment": ["full", "part"],
    "schedule": ["fullDay", "flexible"]
  },
  "resume": {
    "default_id": "1234567890abcdef",
    "auto_update": true
  },
  "monitoring": {
    "check_status": true,
    "export_report": true,
    "report_file": "reports/example_report.txt"
  }
}